# Discord bot token from https://discord.com/developers/applications
BOT_TOKEN=

# Roblox Open Cloud API key from https://create.roblox.com/dashboard/credentials
# Needs group:read and group:write scopes on your target group
ROBLOX_API_KEY=

# Optional: Bloxlink API key for auto-verification
# Users already verified through Bloxlink can skip the manual process
# Get a key at https://blox.link/dashboard/developer
BLOXLINK_API_KEY=
